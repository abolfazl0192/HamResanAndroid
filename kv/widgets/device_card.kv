#:import dp kivy.metrics.dp
#:import sp kivy.metrics.sp


<DeviceCard>:


    size_hint_x: 1
    size_hint_y: None
    height: dp(170)

    radius:
        [dp(22), dp(22), dp(22), dp(22)]

    elevation:
        0



    FloatLayout:



        Image:

            source:
                "assets/cards/device_card_bg.png"

            size_hint:
                1,1

            pos_hint:
                {"center_x":0.5,"center_y":0.5}

            allow_stretch:
                True

            keep_ratio:
                False



        # چراغ وضعیت

        Widget:

            size_hint:
                None,None

            size:
                dp(6),dp(6)

            pos_hint:
                {
                "right":0.94,
                "top":0.84
                }


            canvas:

                Color:

                    rgba:
                        .18,.95,.35,1


                Ellipse:

                    pos:
                        self.pos

                    size:
                        self.size


        # عنوان کارت

        PersianLabel:

            fa_text:
                "دستگاه من"

            font_name:
                "Vazir"

            font_size:
                sp(16)

            bold:
                True

            size_hint:
                .4,None

            height:
                dp(25)

            pos_hint:
                {"right":0.92,"top":0.85}

            halign:
                "right"

            valign:
                "middle"

            text_size:
                self.size

            theme_text_color:
                "Custom"

            text_color:
                1,1,1,1



        # اسم دستگاه

        MDLabel:

            text:
                root.device_name

            font_name:
                "Vazir"

            font_size:
                sp(22)

            bold:
                True

            size_hint:
                .8,None

            height:
                dp(40)

            pos_hint:
                {"center_x":0.5,"center_y":0.55}

            halign:
                "center"

            valign:
                "middle"

            text_size:
                self.size

            theme_text_color:
                "Custom"

            text_color:
                1,1,1,1



        # آی پی

        MDBoxLayout:

            size_hint:
                None, None

            size:
                dp(180), dp(25)

            pos_hint:
                {"center_x":0.53,"center_y":0.28}

            orientation:
                "horizontal"

            spacing:
                dp(3)



            MDIcon:

                icon:
                    "wifi"

                icon_size:
                    dp(18)

                size_hint:
                    None, None

                size:
                    dp(22), dp(22)

                theme_icon_color:
                    "Custom"

                icon_color:
                    .8,.9,1,1



            MDLabel:

                text:
                    root.device_ip

                font_name:
                    "Vazir"

                font_size:
                    sp(13)

                size_hint:
                    1, None

                height:
                    dp(25)

                halign:
                    "left"

                valign:
                    "middle"

                text_size:
                    self.size

                theme_text_color:
                    "Custom"

                text_color:
                    .8,.9,1,1