#:import dp kivy.metrics.dp


<HomeScreen>:


    FloatLayout:


        ScrollView:

            do_scroll_x: False

            do_scroll_y: True



            MDBoxLayout:

                orientation: "vertical"

                padding: dp(15)

                spacing: dp(15)

                size_hint_y: None

                height: self.minimum_height



                AppBar:



                ProfileCard:



                DeviceCard:



                ActionButtons:



                DevicesSection:

                    id: devices_section



                HistorySection:




        BottomNav: